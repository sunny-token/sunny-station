generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SSQResult {
  id              Int      @id @default(autoincrement())
  issueNumber     String   @unique
  openDate        DateTime
  openNumbers     Json
  ballOrder       String
  totalBet        String
  jackpot         String
  detail          String
  prizeAmounts    Json?
  prizeDetailHtml String?
  createdAt       DateTime @default(now())

  @@index([openDate])
}

model DLTResult {
  id              Int      @id @default(autoincrement())
  issueNumber     String   @unique
  openDate        DateTime
  openNumbers     Json
  ballOrder       String
  totalBet        String
  jackpot         String
  detail          String
  prizeAmounts    Json?
  prizeDetailHtml String?
  createdAt       DateTime @default(now())

  @@index([openDate])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  userId      String?
  lotteryType String
  name        String
  numbers     Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@index([lotteryType, isActive])
  @@index([userId])
}

model EmailRecipient {
  id        Int      @id @default(autoincrement())
  userId    String
  email     String
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([isActive])
  @@index([userId])
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  name            String?
  role            Role             @default(USER)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  emailRecipients EmailRecipient[]
  tickets         Ticket[]

  @@index([email])
}

model GitHubProject {
  id          Int      @id @default(autoincrement())
  repoPath    String   @unique
  isPublished Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@index([repoPath])
}

model SkillProject {
  id          Int      @id @default(autoincrement())
  skillSlug   String   @unique
  name        String?
  source      String?
  githubUrl   String?
  isPublished Boolean  @default(false)
  sentAt      DateTime @default(now())

  @@index([skillSlug])
  @@index([githubUrl])
}

enum Role {
  USER
  ADMIN
  GUEST
}
