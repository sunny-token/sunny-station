generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SSQResult {
  id              Int      @id @default(autoincrement())
  issueNumber     String
  openDate        DateTime
  openNumbers     Json
  ballOrder       String
  totalBet        String
  jackpot         String
  detail          String
  prizeAmounts    Json? // 各等奖的奖金数组 [{ level: "一等奖", amount: "5000000" }, ...]
  prizeDetailHtml String?  @db.Text // 从 getdetail 接口获取的原始 HTML
  createdAt       DateTime @default(now())

  @@unique([issueNumber])
  @@index([openDate])
}

model DLTResult {
  id              Int      @id @default(autoincrement())
  issueNumber     String
  openDate        DateTime
  openNumbers     Json
  ballOrder       String
  totalBet        String
  jackpot         String
  detail          String
  prizeAmounts    Json? // 各等奖的奖金数组 [{ level: "一等奖", amount: "5000000" }, ...]
  prizeDetailHtml String?  @db.Text // 从 getdetail 接口获取的原始 HTML
  createdAt       DateTime @default(now())

  @@unique([issueNumber])
  @@index([openDate])
}

// 预设号码表（支持双色球和大乐透）
model Ticket {
  id          Int      @id @default(autoincrement())
  lotteryType String // "ssq" 或 "dlt"
  name        String // 预设号码名称/备注
  numbers     Json // { red: string[], blue: string[] }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lotteryType, isActive])
}

// 邮件收件人表
model EmailRecipient {
  id        Int      @id @default(autoincrement())
  email     String
  name      String? // 收件人名称（可选）
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email])
  @@index([isActive])
}

// -------------------------------------------------------------
// Authentication System (Auth)
// -------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

// 系统用户表
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // 存储 bcrypt 加密后的 hash 值
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([email])
}
